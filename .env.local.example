# Copy this file to .env.local and fill in your own key — .env.local is
# already gitignored, so it will never get committed.

# Required only for Estimating > "Generate from Drawing" (AI-drafted
# estimate line items from an uploaded floor plan/elevation/sketch).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
