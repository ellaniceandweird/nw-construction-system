# Copy this file to .env.local and fill in your own values — .env.local is
# already gitignored, so it will never get committed.

# Required only for Estimating > "Generate from Drawing" (AI-drafted
# estimate line items from an uploaded floor plan/elevation/sketch).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required only for the "Browse Google Drive" buttons in Documents
# (Documents, Drawings, and Photos tabs) — lets you pick a file from your
# own Drive visually instead of pasting a share link by hand.
#
# One-time setup (about 10 minutes):
#   1. Go to https://console.cloud.google.com and create a new project
#      (or use an existing one).
#   2. Under "APIs & Services > Library", enable both:
#        - Google Drive API
#        - Google Picker API
#   3. Under "APIs & Services > Credentials":
#        - Create an API key -> use it as NEXT_PUBLIC_GOOGLE_API_KEY below.
#        - Create an OAuth 2.0 Client ID (type: Web application).
#          Add http://localhost:3000 as an Authorized JavaScript origin.
#          Use the Client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID below.
#   4. Under "OAuth consent screen", add your own Google account as a
#      test user (needed while the app is in "Testing" mode).
#   5. Restart `npm run dev` after saving this file as .env.local.
#
# These are NEXT_PUBLIC_ because the picker runs in the browser — they
# aren't secret in the way an API key normally is, since Google's picker
# still requires the person to sign in and grant access themselves.
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-api-key-here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-oauth-client-id-here.apps.googleusercontent.com
